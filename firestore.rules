rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global safety helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'ghanaforexfintechcryptoexpo@gmail.com' && request.auth.token.email_verified == true;
    }

    // 1. Support Tickets Rules
    function isValidSupportTicket(data) {
      return data.keys().hasAll(['name', 'email', 'topic', 'message'])
        && data.keys().size() <= 7
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && (!('orderNum' in data) || (data.orderNum is string && data.orderNum.size() <= 64))
        && data.topic is string && data.topic.size() <= 64
        && data.message is string && data.message.size() <= 1000;
    }

    match /support_tickets/{ticketId} {
      allow create: if isValidId(ticketId) && isValidSupportTicket(incoming());
      allow read, update, delete: if false; // Secure from outside read/tamper
    }

    // 2. User Reviews Rules
    function isValidUserReview(data) {
      return data.keys().hasAll(['productId', 'author', 'rating', 'comment'])
        && data.keys().size() <= 10
        && data.productId is string && data.productId.size() <= 64
        && data.author is string && data.author.size() <= 100
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.comment is string && data.comment.size() <= 1000
        && (!('title' in data) || (data.title is string && data.title.size() <= 150))
        && (!('userId' in data) || (data.userId is string && data.userId.size() <= 128 && (!isSignedIn() || data.userId == request.auth.uid)))
        && (!('verified' in data) || data.verified is bool);
    }

    match /user_reviews/{reviewId} {
      allow read: if true; // Public reviews
      allow create: if isValidId(reviewId) && isValidUserReview(incoming());
      allow update, delete: if false; // Immutable after review submitted
    }

    // 3. User Orders Rules
    function isValidUserOrder(data) {
      return data.keys().hasAll(['shipName', 'shipEmail', 'shipAddress', 'shipCity', 'shipZip', 'total', 'items'])
        && data.keys().size() <= 13
        && data.shipName is string && data.shipName.size() <= 100
        && data.shipEmail is string && data.shipEmail.size() <= 150
        && data.shipAddress is string && data.shipAddress.size() <= 200
        && data.shipCity is string && data.shipCity.size() <= 100
        && data.shipZip is string && data.shipZip.size() <= 20
        && data.total is number && data.total >= 0
        && data.items is list && data.items.size() > 0 && data.items.size() <= 20
        && (!('userId' in data) || (data.userId is string && data.userId.size() <= 128 && (!isSignedIn() || data.userId == request.auth.uid)));
    }

    match /user_orders/{orderId} {
      // List rules: MUST explicitly enforce query safety
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(orderId) && isValidUserOrder(incoming());
      allow update, delete: if false; // Orders are immutable
    }

    // 4. Products Rules
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'goal', 'basePrice', 'colorTheme', 'colorGradStart', 'colorGradEnd', 'benefits', 'activeIngredients', 'directions', 'storageWarnings'])
        && data.keys().size() <= 25
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 150
        && (!('tagline' in data) || (data.tagline is string && data.tagline.size() <= 200))
        && data.goal is string && data.goal.size() <= 50
        && (!('shortHook' in data) || (data.shortHook is string && data.shortHook.size() <= 1000))
        && data.basePrice is number && data.basePrice >= 0
        && (!('rating' in data) || (data.rating is number))
        && (!('reviewsCount' in data) || (data.reviewsCount is int))
        && data.colorTheme is string && data.colorTheme.size() <= 30
        && (!('imageUrl' in data) || (data.imageUrl is string))
        && (!('imageUrls' in data) || (data.imageUrls is list))
        && (!('videoUrl' in data) || (data.videoUrl is string))
        && (!('sizes' in data) || (data.sizes is list))
        && data.benefits is list && data.benefits.size() <= 20
        && data.activeIngredients is list && data.activeIngredients.size() <= 20
        && data.directions is string && data.directions.size() <= 1000
        && data.storageWarnings is list && data.storageWarnings.size() <= 20
        && data.colorGradStart is string && data.colorGradStart.size() <= 20
        && data.colorGradEnd is string && data.colorGradEnd.size() <= 20
        && (!('seoTitle' in data) || (data.seoTitle is string && data.seoTitle.size() <= 200))
        && (!('seoDescription' in data) || (data.seoDescription is string && data.seoDescription.size() <= 500))
        && (!('detailedCopy' in data) || (data.detailedCopy is string && data.detailedCopy.size() <= 2000))
        && (!('specifications' in data) || (data.specifications is list));
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isValidId(productId) && isAdmin() && isValidProduct(incoming());
    }
  }
}
